# Vision Label Skill — API config
# Copy to .env and fill in real values. Never commit .env.

# Required
VISION_API_KEY=sk-your-key-here

# Base URL (no trailing path). Examples:
#   https://api.openai.com/v1
#   https://api.anthropic.com
#   https://api.example.com/v1
VISION_API_BASE=https://api.openai.com/v1

# Model name
VISION_MODEL=gpt-4o

# API style — one of:
#   openai_chat      → POST {base}/chat/completions   (OpenAI Chat Completions)
#   openai_responses → POST {base}/responses          (OpenAI Responses API)
#   anthropic        → POST {base}/v1/messages or {base}/messages  (Anthropic Messages)
#
# Legacy aliases also accepted: openai → openai_chat, responses → openai_responses, messages → anthropic
VISION_API_FORMAT=openai_chat

# Optional
VISION_MAX_TOKENS=8192
# Override full endpoint URL if your gateway uses a non-standard path
# VISION_API_URL=
